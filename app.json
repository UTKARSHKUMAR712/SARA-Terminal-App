{
  "expo": {
    "name": "SARA Terminal",
    "slug": "sara-terminal",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0d1117",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.sara.terminal",
      "permissions": [
        "INTERNET"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sara.terminal"
    },
    "plugins": [
      "expo-asset",
      "expo-status-bar",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f7c18f3b-7979-496d-a784-b12b338fd3bd"
      }
    },
    "owner": "utkarsh712"
  }
}
