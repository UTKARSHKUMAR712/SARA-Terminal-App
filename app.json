{
  "expo": {
    "name": "SARA Terminal",
    "slug": "sara-terminal",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0d1117",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.sara.terminal",
      "permissions": [
        "INTERNET"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sara.terminal"
    },
    "plugins": [
      "expo-asset",
      "expo-status-bar",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0d1117",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}
